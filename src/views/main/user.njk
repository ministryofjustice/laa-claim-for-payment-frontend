{% extends "base.njk" %}

{% block content %}
  <h1 class="govuk-heading-xl">Who am I?</h1>

  <h2>Welcome, {{ user.name }}</h2>
  <p><strong>Username:</strong> {{ user.preferred_username }}</p>
  <p><strong>Email:</strong> {{ user.email }}</p>

  <h2>All claims</h2>
  <ul>
    {% for key, value in user %}
      <li><strong>{{ key }}</strong>: {{ value }}</li>
    {% endfor %}
  </ul>
{% endblock %}
