{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% extends "base.njk" %}

{% set title = t('pages.poa.checkYourDetails.title') %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('pages.poa.checkYourDetails.title') }}</h1>
      {{ govukTable(vm.assessmentSummaryTable | translate) }}
    </div>
  </div>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h2 class="govuk-heading-m">{{ t('pages.poa.checkYourDetails.cya.title') }}</h2>
      {{ govukSummaryList(vm.profitCostDetailsSummaryList | translate) }}
      {{ govukSummaryList(vm.profitCostBillLineSummaryList | translate) }}
      {{ govukSummaryList(vm.evidenceSummaryList | translate) }}

      {% for summaryList in vm.expertCostBillLineSummaryLists %}
        {{ govukSummaryList(summaryList | translate) }}
      {% endfor %}

      <form method="post">
        {{ govukButton({
          text: t("common.submit")
        }) }}
      </form>
    </div>
  </div>
{% endblock %}