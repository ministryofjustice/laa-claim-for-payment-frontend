{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% extends "base.njk" %}

{% set title = t('pages.poa.checkYourDetails.title') %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ govukTable(vm.assessmentSummaryTable | translate) }}
    </div>
  </div>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h2 class="govuk-heading-m">{{ t('pages.poa.checkYourDetails.cya.title') }}</h2>
      {{ govukSummaryList(vm.profitCostDetailsSummaryList | translate) }}
      {{ govukSummaryList(vm.profitCostBillLineSummaryList | translate) }}
      {{ govukSummaryList(vm.evidenceSummaryList | translate) }}
    </div>
  </div>
{% endblock %}