{% from "govuk/components/date-input/macro.njk" import govukDateInput %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% extends "base.njk" %}

{% set title = t(vm.title) %}
{% set showBackLink = true %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    {% if vm.errorSummary.errorList.length %}
      {{ govukErrorSummary(vm.errorSummary | translate) }}
    {% endif %}

    <form method="post">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">

      <h1 class="govuk-heading-l">
        {{ t("pages.profitCostBillLine.title") }}
      </h1>

      {{ govukDateInput({
        id: "activityDate",
        fieldset: {
          legend: {
            text: t("pages.profitCostBillLine.activityDate.title"),
            classes: "govuk-fieldset__legend--m"
          }
        },
        hint: {
          text: t("pages.profitCostBillLine.activityDate.hint")
        },
        errorMessage: vm.form.activityDateError | translate,
        items: [
          {
            id: "activityDate-day",
            name: "activityDateDay",
            value: vm.form.activityDateDay,
            classes: "govuk-input--width-2" + (" govuk-input--error" if "day" in (vm.form.activityDateError.fields or []) else ""),
            label: t("pages.profitCostBillLine.activityDate.day")
          },
          {
            id: "activityDate-month",
            name: "activityDateMonth",
            value: vm.form.activityDateMonth,
            classes: "govuk-input--width-2" + (" govuk-input--error" if "month" in (vm.form.activityDateError.fields or []) else ""),
            label: t("pages.profitCostBillLine.activityDate.month")
          },
          {
            id: "activityDate-year",
            name: "activityDateYear",
            value: vm.form.activityDateYear,
            classes: "govuk-input--width-4" + (" govuk-input--error" if "year" in (vm.form.activityDateError.fields or []) else ""),
            label: t("pages.profitCostBillLine.activityDate.year")
          }
        ]
      }) }}

      {{ govukInput({
        id: "actualNetProfitCostExcludingAdvocacy",
        name: "actualNetProfitCostExcludingAdvocacy",
        value: vm.form.actualNetProfitCostExcludingAdvocacy,
        classes: "govuk-input--width-5",
        label: {
          text: t("pages.profitCostBillLine.actualNetProfitCostExcludingAdvocacy.title"),
          classes: "govuk-label--m"
        },
        errorMessage: vm.form.actualNetProfitCostExcludingAdvocacyError | translate,
        prefix: {
          text: "£"
        },
        inputmode: "decimal"
      }) }}

      {{ govukInput({
        id: "actualNetAdvocacyCosts",
        name: "actualNetAdvocacyCosts",
        value: vm.form.actualNetAdvocacyCosts,
        classes: "govuk-input--width-5",
        label: {
          text: t("pages.profitCostBillLine.actualNetAdvocacyCosts.title"),
          classes: "govuk-label--m"
        },
        errorMessage: vm.form.actualNetAdvocacyCostsError | translate,
        prefix: {
          text: "£"
        },
        inputmode: "decimal"
      }) }}

      {{ govukRadios({
        name: "vatApplies",
        fieldset: {
          legend: {
            text: t("pages.profitCostBillLine.vatApplies.title"),
            classes: "govuk-fieldset__legend--m"
          }
        },
        errorMessage: vm.form.vatAppliesError | translate,
        items: [
          {
            value: "yes",
            text: t("common.yes"),
            checked: vm.form.vatApplies === "yes"
          },
          {
            value: "no",
            text: t("common.no"),
            checked: vm.form.vatApplies === "no"
          }
        ]
      }) }}

      {{ govukInput({
        id: "feeEarnerName",
        name: "feeEarnerName",
        value: vm.form.feeEarnerName,
        label: {
          text: t("pages.profitCostBillLine.feeEarnerName.title"),
          classes: "govuk-label--m"
        },
        errorMessage: vm.form.feeEarnerNameError | translate
      }) }}

      <div class="govuk-button-group">
        {{ govukButton({
          text: t("common.saveAndContinue")
        }) }}

        <a href="#" class="govuk-button govuk-button--secondary">
          {{ t("common.saveAndComeBackLater") }}
        </a>
      </div>

    </form>

  </div>
</div>
{% endblock %}