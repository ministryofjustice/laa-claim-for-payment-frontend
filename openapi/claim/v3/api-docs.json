          "ufn": {
            "type": "string",
            "description": "universal file number"
          },
          "client": {
            "type": "string",
            "description": "client name"
          },
          "category": {
            "type": "string",
            "description": "claim category"
          },
          "concluded": {
            "type": "string",
            "format": "date",
            "description": "claim concluded date"
          },
          "feeType": {
            "type": "string",
            "description": "fee type"
          },
          "escaped": {
