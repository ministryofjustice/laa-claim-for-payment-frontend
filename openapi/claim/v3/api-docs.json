          },
          "counselPayment": {
            "type": "string",
            "description": "counsel payment"
          },
          "claimed": {
            "type": "number",
            "description": "amount claimed"
          },
          "submissionId": {
            "type": "string",
            "format": "uuid",
            "description": "id of the submission this claim links to"
          }
        },
        "required": [
          "client",
          "ufn"
        ]
